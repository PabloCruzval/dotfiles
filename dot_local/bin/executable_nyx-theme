#!/bin/bash

# Configuration
CACHE_DIR="$HOME/.cache/theme"
NOCTALIA_DIR="$HOME/.config/noctalia/colorschemes/"



mkdir -p "$CACHE_DIR"

apply_theme() {
    local THEME_NAME="$1"
    local NEW_MODE="$2"
    local THEME_DIR="$NOCTALIA_DIR/${THEME_NAME}"
    local THEME_FILE="$THEME_DIR/${THEME_NAME}.json"
    local CURRENT_MODE=$(jq -r '.mode' "$CACHE_DIR/status.json")

    if [ ! -d "$THEME_DIR" -o ! -f "$THEME_FILE" ]; then
        echo "Error: The theme '$THEME_NAME' does not exist in $NOCTALIA_DIR"
        echo "Available themes:"
        ls -1 "$NOCTALIA_DIR" 2>/dev/null | sed 's/\.json$//' | sed 's/^/  - /'
        exit 1
    fi

    # Initialize status.json if it doesn't exist
    if [ ! -f "$CACHE_DIR/status.json" ]; then
        echo '{"theme": "Green", "mode": "dark"}' > "$CACHE_DIR/status.json"
        CURRENT_MODE="dark"
    fi

    if [ -n "$NEW_MODE" ]; then
        echo "Switching to $NEW_MODE mode..."
        CURRENT_MODE="$NEW_MODE"
    fi

    echo "Applying theme: $THEME_NAME..."

    ACTIVE_HEX=$(jq -r ".$CURRENT_MODE.mPrimary" "$THEME_FILE" | tr -d '#')
    INACTIVE_HEX=$(jq -r ".$CURRENT_MODE.mOutline" "$THEME_FILE" | tr -d '#')
    SHADOW_HEX=$(jq -r ".$CURRENT_MODE.mShadow" "$THEME_FILE" | tr -d '#')

    TMP_HYPR_COLORS=$(mktemp "$CACHE_DIR/hyprland_colors.conf.XXXXXX")
    cat <<EOF > "$TMP_HYPR_COLORS"
\$active_border = rgba(${ACTIVE_HEX}ff)
\$inactive_border = rgba(${INACTIVE_HEX}ff)
\$shadow_color = rgba(${SHADOW_HEX}ee)
EOF
    mv "$TMP_HYPR_COLORS" "$CACHE_DIR/hyprland_colors.conf"

    echo "{\"theme\": \"$THEME_NAME\", \"mode\": \"$CURRENT_MODE\"}" > "$CACHE_DIR/status.json"  
    hyprctl reload > /dev/null

    if [ "$CURRENT_MODE" = "dark" ]; then
        gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
        gsettings set org.gnome.desktop.interface gtk-theme "Adwaita-dark"
        qs -c noctalia-shell ipc call darkMode setDark
        echo "Applied dark mode"
    else
        gsettings set org.gnome.desktop.interface color-scheme "prefer-light"
        gsettings set org.gnome.desktop.interface gtk-theme "Adwaita"
        qs -c noctalia-shell ipc call darkMode setLight
        echo "Applied light mode"
    fi

}

toggle_theme() {
    local CURRENT_THEME_FILE="$CACHE_DIR/status.json"

    if [ ! -f "$CURRENT_THEME_FILE" ]; then
        cat '{"theme": "Green", "mode": "dark"}' > "$CURRENT_THEME_FILE"
        apply_theme "Green"
    else
        CURRENT_MODE=$(jq -r '.mode' "$CURRENT_THEME_FILE" 2>/dev/null)
        
        if [ "$CURRENT_MODE" = "dark" ]; then
            apply_theme "Green" "light"
        else
            apply_theme "Green" "dark"
        fi
    fi
}

sync_theme() {
    local MINUTES=$(( $(date +%H) * 60 + $(date +%M) ))
    local CURRENT_THEME_FILE="$CACHE_DIR/status.json"

    if [ ! -f "$CURRENT_THEME_FILE" ]; then
        cat '{"theme": "Green", "mode": "dark"}' > "$CURRENT_THEME_FILE"
    fi

    local THEME=$(jq -r '.theme' "$CURRENT_THEME_FILE" 2>/dev/null)
    local MODE=$(jq -r '.mode' "$CURRENT_THEME_FILE" 2>/dev/null)

    if [ "$MINUTES" -ge 360 ] && [ "$MINUTES" -le 1170 ]; then
        apply_theme "$THEME" "light"
    else
        apply_theme "$THEME" "dark"
    fi
}

show_usage() {
    cat <<EOF
Usage: nyx-theme <command> [arguments]

Commands:
  apply <name> [mode]   Apply a specific theme by name, optionally specifying 'light' or 'dark' mode
  toggle                Toggle between light and dark themes
  sync                  Sync theme based on current time of day

Examples:
  nyx-theme apply Green
  nyx-theme toggle
  nyx-theme sync

Available themes:
$(ls -1 "$NOCTALIA_DIR" 2>/dev/null | sed 's/^/  - /')
EOF
}

case "$1" in
    apply)
        if [ -z "$2" ]; then
            echo "Error: Theme name required"
            echo "Usage: nyx-theme apply <theme-name>"
            exit 1
        fi
        if [[ -n "$3" && "$3" != "light" && "$3" != "dark" ]]; then
            echo "Error: Invalid mode '$3'. Use 'light' or 'dark'."
            echo "Usage: nyx-theme apply <theme-name> [light|dark]"
            exit 1
        fi
        apply_theme "$2" "$3"
        ;;
    toggle)
        toggle_theme
        ;;
    sync)
        sync_theme
        ;;
    -h|--help|help)
        show_usage
        ;;
    *)
        echo "Error: Unknown command '$1'"
        echo
        show_usage
        exit 1
        ;;
esac
